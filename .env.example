# Example environment variables for local development and Vercel
# Copy this file to .env and fill in values before running locally.

# Server
PORT=3000

# MongoDB connection string (if used)
MONGODB_URI=mongodb://localhost:27017/birthday-blog

# Session secret used by express-session
SESSION_SECRET=replace-with-secure-random-string

# Email (for nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Cloudinary (if used for uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT secret (if used)
JWT_SECRET=replace-with-secure-random-string
