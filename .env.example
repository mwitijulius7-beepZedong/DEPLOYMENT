# Copy this file to .env and fill values
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_CLIENT_ID.apps.googleusercontent.com
ALLOWED_EMAIL=        # optional: restrict to single email (e.g. admin@yourdomain.com)
ALLOWED_DOMAIN=       # optional: restrict to a domain (e.g. yourdomain.com)
SESSION_SECRET=change-me-in-production
PORT=3000
